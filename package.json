{
  "name": "@fetchkit/ffetch",
  "version": "5.5.1",
  "description": "Fetch wrapper with configurable timeouts, retries, and TypeScript-first DX",
  "keywords": [
    "fetch",
    "http",
    "retry",
    "timeout",
    "typescript"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fetch-kit/ffetch.git"
  },
  "homepage": "https://github.com/fetch-kit/ffetch#readme",
  "bugs": "https://github.com/fetch-kit/ffetch/issues",
  "author": "Gabor Koos <gabor@gaborkoos.com>",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins/dedupe": {
      "types": "./dist/plugins/dedupe.d.ts",
      "import": "./dist/plugins/dedupe.js",
      "require": "./dist/plugins/dedupe.cjs"
    },
    "./plugins/bulkhead": {
      "types": "./dist/plugins/bulkhead.d.ts",
      "import": "./dist/plugins/bulkhead.js",
      "require": "./dist/plugins/bulkhead.cjs"
    },
    "./plugins/hedge": {
      "types": "./dist/plugins/hedge.d.ts",
      "import": "./dist/plugins/hedge.js",
      "require": "./dist/plugins/hedge.cjs"
    },
    "./plugins/circuit": {
      "types": "./dist/plugins/circuit.d.ts",
      "import": "./dist/plugins/circuit.js",
      "require": "./dist/plugins/circuit.cjs"
    },
    "./plugins/response-shortcuts": {
      "types": "./dist/plugins/response-shortcuts.d.ts",
      "import": "./dist/plugins/response-shortcuts.js",
      "require": "./dist/plugins/response-shortcuts.cjs"
    },
    "./plugins/request-shortcuts": {
      "types": "./dist/plugins/request-shortcuts.d.ts",
      "import": "./dist/plugins/request-shortcuts.js",
      "require": "./dist/plugins/request-shortcuts.cjs"
    },
    "./plugins/download-progress": {
      "types": "./dist/plugins/download-progress.d.ts",
      "import": "./dist/plugins/download-progress.js",
      "require": "./dist/plugins/download-progress.cjs"
    },
    "./plugins/context-id": {
      "types": "./dist/plugins/context-id.d.ts",
      "import": "./dist/plugins/context-id.js",
      "require": "./dist/plugins/context-id.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:ci": "vitest --run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier -w src",
    "version": "changeset version",
    "prepublishOnly": "npm run build && npm run test:ci"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsr": "^0.14.3",
    "lint-staged": "^17.0.5",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
